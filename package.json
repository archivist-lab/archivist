{
  "name": "archivist",
  "version": "1.0.0",
  "private": true,
  "packageManager": "pnpm@9.15.9",
  "scripts": {
    "bootstrap": "corepack pnpm install && corepack pnpm build",
    "build:packages": "corepack pnpm -r --filter \"./packages/*\" build",
    "build:server": "corepack pnpm --filter archivist-server build",
    "build:client": "corepack pnpm --filter archivist-client build",
    "build": "corepack pnpm build:packages && corepack pnpm build:server && corepack pnpm build:client && corepack pnpm build:player",
    "dev": "tsx watch --env-file=.env apps/server/src/server.ts",
    "start": "node apps/server/dist/server.js",
    "test:db": "corepack pnpm --filter @archivist/db test",
    "test": "corepack pnpm test:db && corepack pnpm --filter archivist-server test",
    "test:player": "corepack pnpm --filter archivist-player test",
    "typecheck": "corepack pnpm --filter archivist-server typecheck",
    "verify": "corepack pnpm build && corepack pnpm test && corepack pnpm test:player",
    "push": "bash scripts/push.sh",
    "build:player": "corepack pnpm --filter archivist-player build"
  },
  "devDependencies": {
    "tsx": "4.21.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "better-sqlite3",
      "esbuild",
      "ffmpeg-static",
      "utp-native"
    ]
  }
}
