# ── Archivist ──────────────────────────────────────────────────────────────

# TMDB — movies (required)
# https://www.themoviedb.org/settings/api
TMDB_API_KEY=

# TVDB — TV series (required)
# https://thetvdb.com/api-information
TVDB_API_KEY=
TVDB_PIN=

# Google Books — books (optional, falls back to OpenLibrary)
# https://console.cloud.google.com → Books API
GOOGLE_BOOKS_API_KEY=

# ComicVine — comics (required for comics)
# https://comicvine.gamespot.com/api
COMICVINE_API_KEY=

# IGDB — games (required for games, via Twitch)
# https://api-docs.igdb.com/#getting-started
IGDB_CLIENT_ID=
IGDB_CLIENT_SECRET=

# Fanart.tv — extra artwork (optional)
# https://fanart.tv/get-an-api-key/
FANART_API_KEY=

# ── Paths (optional — defaults shown) ─────────────────────────────────────────
# ARCHIVIST_CONFIG=./config.toml
# ARCHIVIST_DB=./data/archivist.sqlite
# ARCHIVIST_MEDIA_BASE=./media
# ARCHIVIST_DEFINITIONS_PATH=./data/indexer-definitions

# ── Server ─────────────────────────────────────────────────────────────────────
# ARCHIVIST_PORT=2424
# HOST=0.0.0.0
# ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
# PLAYER_ORIGINS=http://localhost:4242,http://127.0.0.1:4242
# Living-room Player v2 remains opt-in during the rollback window.
# PLAYER_UI_V2_ENABLED=true   # living-room UI is the default; set false to fall back to the legacy player
# PLAYER_UI_DEFAULT_PRESET=categories
# PLAYER_UI_MAX_WIDGET_ITEMS=36
# PLAYER_UI_TELEMETRY_ENABLED=false
# Internal API/service token used by the Player proxy; not an Admin login credential.
# Generate with: openssl rand -hex 32
# ARCHIVIST_API_TOKEN=
# ARCHIVIST_JSON_LIMIT=1mb
# LOG_LEVEL=info
# LOG_FORMAT=text
# DEFINITIONS_OFFLINE=false

# ── Built-in torrent engine ───────────────────────────────────────────────────
# Transmission-style flow: torrents download into TORRENT_INCOMPLETE_DIR, then
# the engine moves the finished payload into TORRENT_DOWNLOAD_DIR (…/complete)
# on completion, from where it is imported into the media library. Both live
# under the ./downloads volume mounted in docker-compose (./downloads:/app/downloads).
# TORRENT_INCOMPLETE_DIR=./downloads/incomplete
# TORRENT_DOWNLOAD_DIR=./downloads/complete
# TORRENT_RESUME_DIR=./data/resume
# TORRENT_FILES_DIR=./data/torrents
# ARCHIVIST_EMBEDDED_TORRENTS=true
# TORRENT_PEER_PORT=2425
# TORRENT_DHT_PORT=2426
# TORRENT_UTP_PORT=2427

# ── Player and imports ────────────────────────────────────────────────────────
# ARCHIVIST_TRANSCODE_CONCURRENCY=2
# ARCHIVIST_LOUDNESS_CONCURRENCY=2
# REMOTE_PATH_MAP=/downloads:/app/downloads/complete
