{
  "name": "archivist-server",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "main": "./dist/app.js",
  "types": "./dist/app.d.ts",
  "exports": {
    ".": {
      "import": "./dist/app.js",
      "types": "./dist/app.d.ts"
    }
  },
  "scripts": {
    "dev": "tsx watch --env-file=../../.env src/server.ts",
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "start": "node dist/server.js",
    "test": "tsx test/run-all.ts",
    "test:foundation": "tsx test/foundation.test.ts",
    "test:libraries": "tsx test/libraries.test.ts",
    "test:films": "tsx test/films.e2e.test.ts",
    "test:series": "tsx test/series.e2e.test.ts",
    "test:music-books": "tsx test/music-books.e2e.test.ts",
    "test:comics-games": "tsx test/comics-games.e2e.test.ts",
    "test:platform": "tsx test/platform.e2e.test.ts",
    "test:system": "tsx test/system.e2e.test.ts"
  },
  "dependencies": {
    "@archivist/contracts": "workspace:*",
    "@archivist/core": "workspace:*",
    "@archivist/db": "workspace:*",
    "@torrentstack/bittorrent": "workspace:*",
    "@torrentstack/indexer-engine": "workspace:*",
    "@torrentstack/torrent-engine": "workspace:*",
    "@torrentstack/types": "workspace:*",
    "axios": "1.6.0",
    "better-sqlite3": "12.11.1",
    "dotenv": "^17.4.1",
    "express": "4.18.0",
    "ffmpeg-static": "^5.3.0",
    "ffprobe-static": "^3.1.0",
    "smol-toml": "^1.3.1",
    "systeminformation": "^5.31.5",
    "zod": "3.22.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.0",
    "@types/express": "^4.17.0",
    "@types/node": "^20.0.0",
    "tsx": "^4.7.0",
    "typescript": "^5.4.0"
  }
}
