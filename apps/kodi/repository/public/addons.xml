<?xml version='1.0' encoding='utf-8'?>
<addons>
  <addon id="plugin.video.archivist" name="Archivist" version="0.4.1" provider-name="Archivist Labs">
    <requires>
      <import addon="xbmc.python" version="3.0.0" />
    </requires>
    <extension point="xbmc.python.pluginsource" library="default.py">
      <provides>video</provides>
    </extension>
    <extension point="xbmc.service" library="service.py" start="login" />
    <extension point="xbmc.addon.metadata">
      <summary lang="en_GB">Play your Archivist film and television library in Kodi</summary>
      <description lang="en_GB">Browse, search and play available Archivist films and episodes with resume, watched-state and subtitle synchronisation.</description>
      <platform>all</platform>
      <license>GPL-3.0-only</license>
      <source>https://github.com/archivist-lab/archivist</source>
    </extension>
  </addon>
  <addon id="repository.archivist" name="Archivist Repository" version="1.0.0" provider-name="Archivist Labs">
    <extension point="xbmc.addon.repository" name="Archivist Add-on Repository">
      <dir>
        <info compressed="false">https://raw.githubusercontent.com/archivist-lab/archivist/main/apps/kodi/repository/public/addons.xml</info>
        <checksum>https://raw.githubusercontent.com/archivist-lab/archivist/main/apps/kodi/repository/public/addons.xml.md5</checksum>
        <datadir zip="true">https://raw.githubusercontent.com/archivist-lab/archivist/main/apps/kodi/repository/public/</datadir>
      </dir>
    </extension>
    <extension point="xbmc.addon.metadata">
      <summary lang="en_GB">Install and automatically update Archivist for Kodi</summary>
      <description lang="en_GB">The official update channel for the Archivist Kodi media client.</description>
      <platform>all</platform>
      <license>GPL-3.0-only</license>
      <source>https://github.com/archivist-lab/archivist</source>
    </extension>
  </addon>
</addons>
